# ─────────────────────────────────────────────────────────────
# RAGSystem configuration. Copy to `.env` and edit.
# Every value has a sensible default; nothing here is strictly required.
# ─────────────────────────────────────────────────────────────

# --- OpenAI ---------------------------------------------------
# Leave unset to run fully offline with the deterministic local
# embedding provider + extractive answerer.
# OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
GENERATION_MODEL=gpt-4.1-mini
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=5

# --- Chunking -------------------------------------------------
CHUNK_TOKENS=400
CHUNK_OVERLAP=60

# --- Retrieval ------------------------------------------------
RETRIEVAL_TOP_K=6
MIN_SCORE=0.0

# Stage-1 retrieval mode (see docs/09-hybrid-retrieval.md):
#   vector -> dense FAISS only
#   bm25   -> sparse BM25 only
#   hybrid -> run both and fuse (default)
RETRIEVAL_MODE=hybrid
HYBRID_FUSION=rrf          # rrf | weighted
RRF_K=60                   # RRF damping constant
HYBRID_ALPHA=0.5           # dense weight for weighted fusion (1-alpha = sparse)

# --- Reranking (stage 2; see docs/08-reranking.md) ------------
# none          -> keep vector order (baseline)
# lexical       -> BM25 term-overlap reranker (offline, default)
# cross_encoder -> sentence-transformers cross-encoder (pip install -r requirements-rerank.txt)
# llm           -> LLM scores each candidate (needs OPENAI_API_KEY)
RERANK_STRATEGY=lexical
RERANK_CANDIDATES=20
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
# RERANK_LLM_MODEL=                     # defaults to GENERATION_MODEL

# --- FAISS ----------------------------------------------------
# flat  -> exact search (IndexFlatIP), best for < ~100k vectors/tenant
# ivf   -> approximate search (IndexIVFFlat), for large corpora
FAISS_INDEX_TYPE=flat
IVF_NLIST=100
IVF_NPROBE=8

# --- Storage --------------------------------------------------
DATA_DIR=./data

# --- Deployment mode (see docs/07-deployment-modes.md) --------
# single_tenant -> one implicit corpus, minimal/optional auth
# multi_tenant  -> per-tenant FAISS indices, registry, admin API, quotas
DEPLOYMENT_MODE=multi_tenant

# Single-tenant knobs (ignored in multi-tenant mode)
SINGLE_TENANT_ID=default
SINGLE_TENANT_REQUIRE_AUTH=false

# Multi-tenant control plane: guards /admin/* tenant management.
# Leave unset to disable the admin API entirely.
# ADMIN_API_KEY=change-me-admin-secret

# Tenant isolation (multi-tenant; see docs/10-tenant-isolation.md):
#   index_per_tenant -> one FAISS index file per tenant (physical, default)
#   shared_namespace -> one shared index partitioned by tenant id (exact
#                       per-namespace search via an id selector)
TENANT_ISOLATION=index_per_tenant

# --- Auth -----------------------------------------------------
# Comma-separated key:tenant pairs. In production use a secrets
# manager + a real identity provider instead of static keys.
# (In multi-tenant mode these tenants are auto-registered at startup.)
API_KEYS=demo-key:demo

# --- Generation guardrails ------------------------------------
MAX_CONTEXT_CHUNKS=6
GENERATION_TEMPERATURE=0.1

# --- Multi-turn chat (see docs/12-multi-turn-chat.md) ---------
CHAT_HISTORY_TURNS=8            # prior messages fed to the generator
CHAT_CONDENSE_QUESTION=true     # rewrite follow-ups into standalone queries

# --- Dialogue manager (see docs/14-dialogue-manager.md) -------
INTENT_STRATEGY=rule                 # rule | llm
INTENT_CONFIDENCE_THRESHOLD=0.5      # below this, non-question intents answer via RAG

# --- Server ---------------------------------------------------
LOG_LEVEL=INFO
